{
  "id": "kindling-agent-ready",
  "version": "0.3.0",
  "name": "Kindling Agent-Ready Environment",
  "description": "Makes a devcontainer agent-ready with the kindling harness.",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "Kindling package version to install"
    }
  },
  "containerEnv": {
    "KINDLING_ENABLED": "true"
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/node",
    "ghcr.io/anthropics/devcontainer-features/claude-code"
  ]
}
